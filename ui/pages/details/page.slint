import { AppHeader, Button, ButtonSection, CardColorPicker, IconButton, HeadingSm, TextSm,
         BasePage, PageBody, ContentSection, ConfirmationModal } from "../../compat/widgets.slint";
import { Importance, Palette, Size } from "../../compat/theme.slint";
import { Callbacks } from "../../callbacks.slint";
import { Navigate } from "../../gen/navigate.slint";

component FieldBlock inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <bool> sensitive;
    in property <bool> blurred;
    callback action-clicked();
    in property <string> action-label;

    background: Palette.background-primary-alternative;
    border-radius: Size.sz3;

    VerticalLayout {
        padding: Size.sz4;
        spacing: Size.sz1;

        HorizontalLayout {
            alignment: space-between;
            HeadingSm {
                text: label;
                color: Palette.content-secondary;
            }
            if sensitive && !blurred: TextSm {
                text: "sensitive";
                color: Palette.content-negative;
            }
        }

        if blurred: TextSm {
            text: "••• hidden •••";
            color: Palette.content-tertiary;
        }

        if !blurred: TextSm {
            text: value;
            color: Palette.content-primary;
            wrap: char-wrap;
        }

        if action-label != "": HorizontalLayout {
            alignment: start;
            padding-top: Size.sz2;
            Button {
                label: action-label;
                importance: sensitive ? Importance.negative : Importance.secondary;
                clicked => { action-clicked(); }
            }
        }
    }
}

export component DetailsPage inherits Rectangle {
    property <bool> show-reveal-confirm: false;
    property <bool> password-revealed: false;
    property <string> password-value: "";

    init => {
        password-revealed = false;
        password-value = "";
    }

    BasePage {
        VerticalLayout {
            AppHeader {
                title: Callbacks.editing-label != "" ? Callbacks.editing-label : "Password";
                title-color: Palette.content-primary;
                side-padding: Size.sz6;

                IconButton {
                    icon: "chevron-left";
                    size: Size.sz8;
                    importance: Importance.normal;
                    clicked => { Navigate.backward(); }
                }
            }

            PageBody {
                ContentSection {
                    spacing: Size.sz4;

                    FieldBlock {
                        label: "Website";
                        value: Callbacks.editing-origin;
                        sensitive: false;
                        blurred: false;
                        action-label: "";
                    }

                    FieldBlock {
                        label: "Username";
                        value: Callbacks.editing-username;
                        sensitive: false;
                        blurred: false;
                        action-label: "";
                    }

                    FieldBlock {
                        label: "Password";
                        value: password-value;
                        sensitive: true;
                        blurred: !password-revealed;
                        action-label: password-revealed ? "Hide" : "Reveal password";
                        action-clicked => {
                            if (password-revealed) {
                                password-revealed = false;
                                password-value = "";
                            } else {
                                show-reveal-confirm = true;
                            }
                        }
                    }

                    CardColorPicker {
                        selected-index: Callbacks.editing-color;
                        title: "Color";
                        changed(index) => {
                            Callbacks.editing-color = index;
                            Callbacks.change-color(Callbacks.editing-uuid, index);
                        }
                    }
                }
            }
        }
    }

    if show-reveal-confirm: ConfirmationModal {
        icon: "alert";
        title: "Reveal password?";
        text: "The next screen will show the password in plaintext. Only do this where nobody can see your screen.";
        cancel-button-label: "Cancel";
        confirm-button-label: "Reveal";
        critical: true;

        cancel-clicked => { show-reveal-confirm = false; }

        confirm-clicked => {
            show-reveal-confirm = false;
            password-value = Callbacks.reveal-password(Callbacks.editing-uuid);
            password-revealed = password-value != "";
        }
    }
}
